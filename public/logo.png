<svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="rhGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1e40af;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Outer Circle -->
  <circle cx="60" cy="60" r="58" fill="none" stroke="url(#rhGradient)" stroke-width="2"/>
  
  <!-- Inner Background Circle -->
  <circle cx="60" cy="60" r="52" fill="#0f172a" opacity="0.8"/>
  
  <!-- RH Text -->
  <text x="60" y="72" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="url(#rhGradient)" text-anchor="middle" letter-spacing="-2">RH</text>
</svg>